{
  "name": "k2ss.info",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "postbuild": "mv build/404/index.html build/404.html && node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "lint": "npm run check && eslint ./src",
    "format": "prettier --write ./src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.4.0",
    "@types/prismjs": "^1.26.6",
    "autoprefixer": "^10.5.0",
    "contentful": "^10.15.1",
    "dayjs": "^1.11.21",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prismjs": "^1.30.0",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.6.1",
    "svelte-fa": "^4.0.4",
    "svelte-meta-tags": "^5.0.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.16 <25",
    "npm": ">=11"
  },
  "type": "module"
}
